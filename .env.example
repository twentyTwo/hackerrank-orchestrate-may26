# Copy this file to .env and fill in your values.
# Never commit .env — it is already in .gitignore.

# Switch between local (Ollama) and cloud (Voyage + Anthropic) backends.
# Values: local | cloud
PROVIDER=local

# Required for cloud embedding (voyage-3-large)
VOYAGE_API_KEY=

# Required for cloud LLM (Claude Sonnet 4)
ANTHROPIC_API_KEY=
